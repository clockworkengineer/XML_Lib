<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
    <xs:element name="postcode">
        <xs:simpleType>
            <xs:restriction base="xs:string">
                <xs:pattern value="[A-Z]{1,2}[0-9][0-9A-Z]? [0-9][A-Z]{2}"/>
            </xs:restriction>
        </xs:simpleType>
    </xs:element>
</xs:schema>