# Doxyfile for XML_Lib
# Generate with: cmake --build build/ --target docs

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "XML_Lib"
PROJECT_NUMBER         = 1.2.0
PROJECT_BRIEF          = "Lightweight C++23 XML parsing, manipulation, and generation library"
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = classes/include
FILE_PATTERNS          = *.hpp
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */implementation/* */interface/XML_Types.hpp

#---------------------------------------------------------------------------
# Build options
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO

#---------------------------------------------------------------------------
# Preprocessor
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = XML_LIB_ENABLE_DTD \
                         XML_LIB_ENABLE_XSD \
                         XML_LIB_ENABLE_XPATH \
                         XML_LIB_ENABLE_STRINGIFY

#---------------------------------------------------------------------------
# Output formats
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_TIMESTAMP         = YES

GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Diagrams (uses dot if available)
#---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_DIAGRAMS         = YES

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
